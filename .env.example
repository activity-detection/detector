# Permitted modes: VIDEO, USB, FOLDER, IMAGE, RTSP
APP_MODE=VIDEO

# Path to video
SOURCE_PATH=data/people-walking-1.mp4

# Path to file containing action vectors in cvs format
ACTION_VECTORS_PATH=vectors/example.csv

# Path to models used in app
BASE_MODEL_PATH=models/saved-models/yolo26m.pt
POSE_MODEL_PATH=models/saved-models/yolo26n-pose.pt
LSTM_MODEL_PATH=models/saved-models/lstm_combined.pth
FIGHT_LSTM_MODEL_PATH=models/saved-models/lstm_fights.pth
FIGHT_SCALER_PATH=models/saved-models/lstm_fights_scaler.pkl

# Batch size used by YOLO models
BATCH_SIZE=8

# FPS / okna LSTM (zsynchronizowane z research-notebooks/config.py)
TARGET_FPS=25
LSTM_WINDOW=30
SCENE_WINDOW=30
LSTM_CONF_THRESHOLD=0.6

# Heurystyki scene-level
LYING_ASPECT_THRESHOLD=1.5
LYING_SUSTAIN_FRAMES=30
CROWD_PERSON_THRESHOLD=20
CROWD_SUSTAIN_FRAMES=15

# Folder in which clips will be saved
CLIP_FOLDER=clips

# Video forwarding
DB_URL=http://localhost:8080/videos/upload

# RTSP Camera settings
CAMERA_USER=user
CAMERA_PASSWORD=password
CAMERA_IP=192.168.1.2
CAMERA_PORT=554
RTSP_PATH=profile1

# Train settings
TRAIN_MODEL_DIR=saved-models
TRAIN_PROJECT_DIR=runs

# Roboflow settings
ROBOFLOW_API_KEY=XXXXXXXXXXXXXXXXXXXX
ROBOFLOW_WORKSPACE=mciurzynski-workspace
ROBOFLOW_PROJECT=license-plate-recognition-rognt
ROBOFLOW_DATASET_VERSION=2